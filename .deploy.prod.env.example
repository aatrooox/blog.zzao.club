# Copy this file to .deploy.prod.env and fill in the remote host fields.
# Keep .deploy.prod.env local-only; do not commit real server addresses or secrets.

REMOTE_HOST=example.com
REMOTE_USER=root
REMOTE_PORT=22

APP_NAME=blog
REMOTE_WWW_DIR=/var/www/blog.nezus.cn

# Local steps.
RUN_INSTALL=true
RUN_LINT=true
RUN_GENERATE=true
LOCAL_INSTALL_CMD="pnpm install --frozen-lockfile"
LOCAL_LINT_CMD="pnpm lint"
LOCAL_GENERATE_CMD="env NODE_OPTIONS=--max-old-space-size=4096 pnpm generate"
